# ============================================================
# NOVO - Variables de Entorno
# ============================================================
# Copia este archivo como .env y reemplaza los valores:
#   cp .env.example .env          (Linux/Mac)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# NUNCA subas el archivo .env a Git (ya está en .gitignore).
# Pide las credenciales al administrador del proyecto.
# ============================================================

# --- Supabase (Auth + Base de datos) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_supabase_anon_public_key

# --- Flask ---
SECRET_KEY=genera_una_clave_con: python -c "import secrets; print(secrets.token_hex(32))"

# --- Google Gemini (Análisis IA de CV + Audio) ---
GEMINI_API_KEY=tu_gemini_api_key
GOOGLE_API_KEY=tu_google_api_key

# --- Perplexity (Búsqueda web de oportunidades) ---
PERPLEXITY_API_KEY=tu_perplexity_api_key

# --- Stripe (Pagos - Plan Premium) ---
STRIPE_SECRET_KEY=tu_stripe_secret_key
STRIPE_PRICE_ID=tu_stripe_price_id

# --- Demo Account (Para testing - NUNCA usar cuenta personal) ---
DEMO_EMAIL=demo@novo.app
DEMO_PASSWORD=tu_demo_account_password
